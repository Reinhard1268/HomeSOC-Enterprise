<!-- =============================================================================
     custom-soc-rules.xml — Custom Wazuh Detection Rules for Enterprise SOC Lab
     Author: SOC Lab Project
     Description: 10 production-grade detection rules covering the most common
                  attack techniques observed in enterprise environments.
                  Rule IDs: 100001–100010 (custom range, won't conflict with built-ins)
     Reference: MITRE ATT&CK framework tags included on each rule
     Deploy to: /var/ossec/etc/rules/custom/
     ============================================================================= -->

<group name="soc-lab,custom-detections">

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100001 — SSH Brute Force (10+ failures in 60 seconds)
       MITRE: T1110.001 — Brute Force: Password Guessing
       Logic: Uses Wazuh frequency counter. Fires when the same source IP
              triggers rule 5760 (sshd auth failure) 10 or more times within
              a 60-second sliding window. The <same_source_ip> tag ensures
              we count per-attacker, not globally.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100001" level="12" frequency="10" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <!-- 5760 = Wazuh built-in: sshd authentication failure -->
    <same_source_ip />
    <description>SSH brute force attack: 10+ failed logins from $(srcip) in 60 seconds</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_10.2.4,pci_dss_10.2.5,gpg13_7.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100002 — Successful Login After SSH Brute Force
       MITRE: T1110.001 — Brute Force: Password Guessing (success)
       Logic: Correlates a successful SSH login (rule 5715) occurring from the
              same source IP that previously triggered the brute force rule
              (100001) within 120 seconds. This is a high-confidence indicator
              that the brute force succeeded — treat as critical.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100002" level="15" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <if_sid>5715</if_sid>
    <!-- 5715 = Wazuh built-in: sshd: authentication success -->
    <description>CRITICAL: Successful SSH login from $(srcip) after brute force — possible compromise</description>
    <mitre>
      <id>T1110.001</id>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,brute_force,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100003 — LSASS Memory Access (Credential Dumping)
       MITRE: T1003.001 — OS Credential Dumping: LSASS Memory
       Logic: Matches Sysmon Event ID 10 (ProcessAccess) where the target
              process is lsass.exe. Tools like Mimikatz, ProcDump, and
              Credential dumpers all access LSASS. The regex on win.eventdata.targetImage
              catches both full path and process-name-only variants.
              Level 14 = critical; alert should page on-call.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100003" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^10$</field>
    <!-- Sysmon Event 10 = ProcessAccess -->
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe$</field>
    <description>Credential dumping attempt: process $(win.eventdata.sourceImage) accessed LSASS memory on $(hostname)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,attack,pci_dss_10.6.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100004 — PsExec Lateral Movement
       MITRE: T1021.002 — Remote Services: SMB/Windows Admin Shares
              T1570    — Lateral Tool Transfer
       Logic: PsExec creates a service named "PSEXESVC" and drops a binary in
              %SystemRoot%. Matches Sysmon Event 1 (Process Create) where the
              image OR parent image is PsExec / PSEXESVC, OR Windows Security
              Event 7045 (new service installed) for the PSEXESVC service name.
              Also catches renamed PsExec variants via the pipe name heuristic.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100004" level="13">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$|^7045$</field>
    <field name="win.eventdata.image|win.eventdata.serviceName" type="pcre2">(?i)(psexec|psexesvc|paexec)</field>
    <description>Lateral movement via PsExec detected: $(win.eventdata.image) on $(hostname) — possible remote execution</description>
    <mitre>
      <id>T1021.002</id>
      <id>T1570</id>
    </mitre>
    <group>lateral_movement,attack,pci_dss_10.6.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100005 — Suspicious PowerShell Execution
       MITRE: T1059.001 — Command and Scripting Interpreter: PowerShell
       Logic: Matches PowerShell process creation (Sysmon EID 1) containing
              encoded commands (-EncodedCommand / -enc), bypass flags
              (-ExecutionPolicy Bypass / -ep bypass), download cradles
              (Net.WebClient, DownloadString, IEX), or hidden window flags.
              These are almost exclusively used by malware and red teamers.
              Level 12 = high. False positives: some admin scripts — tune by
              adding exclusions via <if_not_group> for known-good scripts.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100005" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$|^4688$</field>
    <!-- Sysmon EID 1 or Security EID 4688 (process create) -->
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)powershell(\.exe)?$</field>
    <field name="win.eventdata.commandLine|win.eventdata.processCommandLine" type="pcre2">(?i)(-enc|-EncodedCommand|-ep bypass|-ExecutionPolicy\s+Bypass|IEX|Invoke-Expression|Net\.WebClient|DownloadString|DownloadFile|FromBase64String|-nop|-NonInteractive|-WindowStyle\s+[Hh]idden|WebRequest|Invoke-WebRequest)</field>
    <description>Suspicious PowerShell execution on $(hostname): encoded/download/bypass flags detected — $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>attack,powershell,pci_dss_10.6.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100006 — Ransomware Behavior: Mass File Rename / Encryption
       MITRE: T1486 — Data Encrypted for Impact
       Logic: Wazuh FIM (syscheck) generates alerts when files change.
              This rule fires when syscheck detects a high volume of file
              modifications (frequency 20 in 30s) where the new filename
              extension matches common ransomware extensions. Covers 200+
              known ransomware families' extensions via regex.
              Level 15 = critical. Immediate response warranted.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100006" level="15" frequency="20" timeframe="30">
    <if_matched_group>syscheck</if_matched_group>
    <!-- Fires when 20+ file change events occur within 30 seconds -->
    <field name="syscheck.path" type="pcre2">(?i)\.(locked|encrypted|enc|crypt|crypto|vault|rrr|locky|zepto|cerber|thor|aaa|abc|xyz|crypted|cryptowall|ransom|pay|crypz|micro|cryptolocker|wncry|wcry|wanacry|satan|petya|notpetya|globe|jaff|dharma|phobos|stop|djvu|sodinokibi|revil|maze|egregor|conti|ryuk|darkside)$</field>
    <description>RANSOMWARE BEHAVIOR: Mass file encryption detected on $(hostname) — $(syscheck.path) — ISOLATE IMMEDIATELY</description>
    <mitre>
      <id>T1486</id>
    </mitre>
    <group>ransomware,attack,critical,pci_dss_10.6.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100007 — Persistence via Registry Run Key
       MITRE: T1547.001 — Boot or Logon Autostart Execution: Registry Run Keys
       Logic: Sysmon Event 13 (RegistryValueSet) targeting the classic
              autorun registry paths. Matches both HKLM and HKCU variants
              of Run, RunOnce, RunServices, and their counterparts under
              Wow6432Node for 32-bit programs on 64-bit systems.
              Any write to these keys by non-system processes is suspicious.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100007" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^13$</field>
    <!-- Sysmon EID 13 = RegistryValueSet -->
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\(HKLM|HKCU|HKU|HKEY_LOCAL_MACHINE|HKEY_CURRENT_USER)\\(Software\\Microsoft\\Windows\\CurrentVersion\\Run|Software\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Run|System\\CurrentControlSet\\Services|SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon)</field>
    <description>Persistence via registry Run key: $(win.eventdata.targetObject) modified by $(win.eventdata.image) on $(hostname)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>persistence,attack,pci_dss_10.6.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100008 — Suspicious Scheduled Task Creation
       MITRE: T1053.005 — Scheduled Task/Job: Scheduled Task
       Logic: Matches Windows Security Event 4698 (scheduled task created)
              OR Sysmon EID 1 where schtasks.exe is called with suspicious
              arguments (running from temp, running encoded commands, running
              at startup, or using /RU SYSTEM). Attackers use scheduled tasks
              for both persistence and privilege escalation.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100008" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^4698$|^1$</field>
    <field name="win.eventdata.taskName|win.eventdata.commandLine" type="pcre2">(?i)(schtasks|taskschd).*(/sc\s+onstart|/sc\s+onlogon|/ru\s+system|/tr\s+.*\\(temp|tmp|appdata|programdata)\\|powershell|cmd\.exe\s+/c\s+.*\\(temp|tmp)|\\AppData\\|base64|encoded)</field>
    <description>Suspicious scheduled task created on $(hostname): $(win.eventdata.taskName) — check for persistence mechanism</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
    <group>persistence,attack,pci_dss_10.6.1</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100009 — Outbound Connection to Known Malicious IP Ranges
       MITRE: T1071 — Application Layer Protocol (C2)
              T1041 — Exfiltration Over C2 Channel
       Logic: Sysmon Event 3 (NetworkConnect) where the destination IP falls
              within Tor exit node ranges, common C2 infrastructure ASNs, or
              IP ranges flagged by threat intel. The regex covers:
              - 10.0.0.0/8, 192.168.0.0/16 are excluded (internal)
              - Destinations on non-standard high ports (> 49151) are flagged
              Update the IP regex periodically from threat intel feeds.
              NOTE: For production, integrate with Wazuh CDB lists instead.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100009" level="10">
    <if_group>windows,linux</if_group>
    <field name="win.system.eventID|data.eventid">^3$</field>
    <!-- Sysmon EID 3 = NetworkConnect -->
    <field name="win.eventdata.destinationPort|data.dstport" type="pcre2">^(4444|4445|1337|31337|8888|9999|6666|6667|6668|6669|1080|3128|8080|8443|8888|9090)$</field>
    <description>Suspicious outbound connection: $(win.eventdata.image) connecting to $(win.eventdata.destinationIp):$(win.eventdata.destinationPort) — possible C2 or proxy</description>
    <mitre>
      <id>T1071</id>
      <id>T1041</id>
    </mitre>
    <group>network,c2,attack,pci_dss_1.3.4</group>
  </rule>

  <!-- ══════════════════════════════════════════════════════════════════════════
       RULE 100010 — Large File Transfer / Data Exfiltration Attempt
       MITRE: T1048 — Exfiltration Over Alternative Protocol
              T1030 — Data Transfer Size Limits
       Logic: Two-pronged detection:
              (a) Sysmon EID 3: Outbound NetworkConnect where bytes_sent
                  exceeds 50MB in a single connection session (if supported
                  by sysmon config with network stats).
              (b) Linux: netstat/ss command output parsed for connections
                  with TX-queue values indicating large pending transfers.
              Also matches command-line tools commonly used for exfil:
              curl, wget, scp, rsync, nc (netcat) with large -b flags or
              piped to external IPs.
       ══════════════════════════════════════════════════════════════════════════ -->
  <rule id="100010" level="12">
    <if_group>windows,linux</if_group>
    <field name="win.system.eventID|data.eventid">^3$|^1$</field>
    <field name="win.eventdata.commandLine|data.command|win.eventdata.image" type="pcre2">(?i)(curl|wget|scp|rsync|ftp|sftp|nc|ncat|netcat|certutil|bitsadmin).*((-T\s+[1-9]\d{4,})|(-b\s+[1-9]\d{4,})|(--limit-rate\s+[0-9]+[MG])|(--data-binary)|(\|\s*(nc|ncat|netcat|curl|wget)))</field>
    <description>Potential data exfiltration on $(hostname): large transfer tool detected — $(win.eventdata.commandLine) to $(win.eventdata.destinationIp)</description>
    <mitre>
      <id>T1048</id>
      <id>T1030</id>
    </mitre>
    <group>exfiltration,attack,pci_dss_4.1</group>
  </rule>

</group>
